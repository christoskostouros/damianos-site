---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Επικοινωνία | ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ – Νέο Ηράκλειο"
  description="Επικοινωνήστε μαζί μας: 210 27 76 365. Σαρανταπόρου 27, Νέο Ηράκλειο. Δωρεάν παραλαβή & παράδοση ταπήτων σε όλη την Αττική."
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Επικοινωνία</span>
      <h1 class="page-hero-title">Επικοινωνήστε Μαζί Μας</h1>
      <p class="page-hero-subtitle">Θα χαρούμε πολύ να σας εξυπηρετήσουμε. Καλέστε μας ή συμπληρώστε τη φόρμα.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section section-padding">
    <div class="container">
      <div class="contact-grid">

        <!-- Form -->
        <div class="contact-form-wrapper reveal">
          <h2 class="contact-form-title">Στείλτε μας Μήνυμα</h2>
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-group">
              <label for="name">Ονοματεπώνυμο</label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Το ονοματεπώνυμό σας">
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="email@example.com">
            </div>
            <div class="form-group">
              <label for="phone">Τηλέφωνο</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="210 0000000">
            </div>
            <div class="form-group">
              <label for="message">Μήνυμα</label>
              <textarea id="message" name="message" rows="5" required placeholder="Πώς μπορούμε να σας βοηθήσουμε;"></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg form-submit">Αποστολή Μηνύματος</button>
            <div class="form-feedback" id="form-feedback" hidden></div>
          </form>
        </div>

        <!-- Info + Map -->
        <div class="contact-info-wrapper">
          <div class="contact-info reveal">
            <h2 class="contact-info-title">Στοιχεία Επικοινωνίας</h2>

            <div class="info-card">
              <h3>ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ</h3>
              <p class="info-owner">Ιορδάνης Βογιατζόγλου του Δαμιανού</p>
            </div>

            <div class="info-items">
              <div class="info-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <strong>Διεύθυνση</strong>
                  <p><a href="https://maps.app.goo.gl/QvRyJGtVBXvFkNaH6" target="_blank" rel="noopener noreferrer">Σαρανταπόρου 27, Νέο Ηράκλειο<br>Τ.Κ. 141-21</a></p>
                </div>
              </div>

              <div class="info-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <div>
                  <strong>Τηλέφωνα</strong>
                  <p>
                    <a href="tel:+302102776365">210 27 76 365</a><br>
                    <a href="tel:+302102798261">210 27 98 261</a>
                  </p>
                </div>
              </div>

              <div class="info-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <div>
                  <strong>Email</strong>
                  <p><a href="mailto:info@plisimotapiton.gr">info@plisimotapiton.gr</a></p>
                </div>
              </div>
            </div>

            <div class="info-hours">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <strong>Ωράριο Λειτουργίας</strong>
                <p>Δευτέρα - Παρασκευή: 08:00 - 17:00</p>
                <p>Σάββατο: Κατόπιν ραντεβού</p>
                <p>Κυριακή: Κλειστά</p>
              </div>
            </div>

            <a href="https://maps.app.goo.gl/QvRyJGtVBXvFkNaH6" target="_blank" rel="noopener noreferrer" class="btn btn--outline info-gmb-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Δείτε μας στο Google Maps
            </a>
          </div>

          <!-- Map -->
          <div class="contact-map reveal">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3143.1!2d23.7697!3d38.0487!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14a1a2b2c3d4e5f%3A0x1234567890abcdef!2zzqPOsc-BzrHOvc-EzrHPgM-Mz4HOv8-FIDI3LCDOnc6tzr8gzpfPgc6szrrOu861zrnOvw!5e0!3m2!1sel!2sgr!4v1710000000000!5m2!1sel!2sgr"
              width="100%"
              height="300"
              style="border:0; border-radius: var(--radius-lg);"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Χάρτης - ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Thank you message -->
  <section class="thank-you">
    <div class="container">
      <p class="thank-you-text reveal">«Ευχαριστούμε που επισκεφθήκατε την ιστοσελίδα μας. Θα χαρούμε πολύ να σας εξυπηρετήσουμε!»</p>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--color-cream);
    padding: var(--space-24) 0 var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }
  .page-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.65;
  }

  .contact-section { background: var(--color-bg); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Form */
  .contact-form-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .form-group {
    margin-bottom: var(--space-5);
  }
  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(181, 55, 42, 0.1);
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-faint);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }
  .form-submit {
    width: 100%;
    justify-content: center;
  }
  .form-feedback {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    text-align: center;
  }
  .form-feedback.success {
    background: var(--color-sage-light);
    color: #2D5F45;
  }

  /* Info */
  .contact-info-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
  }
  .info-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }
  .info-owner {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }
  .info-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .info-item svg { flex-shrink: 0; margin-top: 2px; }
  .info-item strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .info-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  .info-item a {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Hours */
  .info-hours {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-5);
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-primary);
    margin-bottom: var(--space-6);
  }
  .info-hours svg { flex-shrink: 0; margin-top: 2px; }
  .info-hours strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .info-hours p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .info-hours p:last-child { margin-bottom: 0; }
  .info-gmb-btn {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-6);
  }

  /* Map */
  .contact-map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  /* Thank You */
  .thank-you {
    background: var(--color-cream);
    padding-block: var(--space-10);
    text-align: center;
  }
  .thank-you-text {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>

<script is:inline>
  const form = document.getElementById('contact-form');
  const feedback = document.getElementById('form-feedback');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    // Simple client-side validation
    const name = form.querySelector('#name').value.trim();
    const email = form.querySelector('#email').value.trim();
    const message = form.querySelector('#message').value.trim();

    if (!name || !email || !message) {
      feedback.hidden = false;
      feedback.className = 'form-feedback';
      feedback.textContent = 'Παρακαλώ συμπληρώστε τα υποχρεωτικά πεδία.';
      feedback.style.background = '#FEE';
      feedback.style.color = '#A33';
      return;
    }

    // Show success (no backend)
    feedback.hidden = false;
    feedback.className = 'form-feedback success';
    feedback.textContent = 'Ευχαριστούμε! Θα επικοινωνήσουμε μαζί σας σύντομα.';
    form.reset();
  });
</script>
