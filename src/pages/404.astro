---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Αυτή η σελίδα χάθηκε κάπου στο χαλί | ΔΑΜΙΑΝΟΣ"
  description="Η σελίδα που ψάχνεις δεν βρέθηκε. Μάλλον ρουφήχτηκε από την ηλεκτρική σκούπα."
>
  <section class="page-404">
    <div class="container">
      <div class="err-inner">

        <div class="err-visual" aria-hidden="true">
          <div class="rug-wrapper">
            <!-- SVG rug with vacuum cleaner pulling a 404 -->
            <svg class="rug-svg" viewBox="0 0 420 280" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Rug body -->
              <rect x="20" y="100" width="320" height="140" rx="8" fill="#C8523A"/>
              <!-- Rug border -->
              <rect x="30" y="110" width="300" height="120" rx="4" fill="none" stroke="#FAF8F5" stroke-width="3"/>
              <rect x="44" y="124" width="272" height="92" rx="2" fill="none" stroke="#FAF8F5" stroke-width="1.5" stroke-dasharray="6 4"/>
              <!-- Rug fringes left -->
              <line x1="20" y1="110" x2="4" y2="100" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="118" x2="4" y2="108" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="126" x2="4" y2="116" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="134" x2="4" y2="124" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="142" x2="4" y2="132" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="150" x2="4" y2="140" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="158" x2="4" y2="148" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="166" x2="4" y2="156" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="174" x2="4" y2="164" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="182" x2="4" y2="172" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="190" x2="4" y2="180" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="198" x2="4" y2="188" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="206" x2="4" y2="196" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="214" x2="4" y2="204" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="222" x2="4" y2="212" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="20" y1="230" x2="4" y2="220" stroke="#FAF8F5" stroke-width="1.5"/>
              <!-- Rug fringes right -->
              <line x1="340" y1="110" x2="356" y2="100" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="118" x2="356" y2="108" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="126" x2="356" y2="116" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="134" x2="356" y2="124" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="142" x2="356" y2="132" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="150" x2="356" y2="140" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="158" x2="356" y2="148" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="166" x2="356" y2="156" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="174" x2="356" y2="164" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="182" x2="356" y2="172" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="190" x2="356" y2="180" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="198" x2="356" y2="188" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="206" x2="356" y2="196" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="214" x2="356" y2="204" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="222" x2="356" y2="212" stroke="#FAF8F5" stroke-width="1.5"/>
              <line x1="340" y1="230" x2="356" y2="220" stroke="#FAF8F5" stroke-width="1.5"/>
              <!-- 404 text on rug -->
              <text x="180" y="178" text-anchor="middle" font-family="Cormorant Garamond, Georgia, serif" font-size="52" font-weight="700" fill="#FAF8F5" opacity="0.9">404</text>
              <!-- Vacuum cleaner -->
              <g transform="translate(300, 60)">
                <!-- Body -->
                <ellipse cx="50" cy="30" rx="38" ry="22" fill="#1A4B8C"/>
                <ellipse cx="50" cy="30" rx="30" ry="16" fill="#2A5FA8"/>
                <!-- Hose going down-left -->
                <path d="M 20 35 Q 5 70 -20 100" stroke="#4B5563" stroke-width="5" fill="none" stroke-linecap="round"/>
                <!-- Nozzle on rug -->
                <rect x="-36" y="95" width="28" height="10" rx="3" fill="#1A4B8C"/>
                <!-- Wheels -->
                <circle cx="30" cy="50" r="8" fill="#1F2937"/>
                <circle cx="70" cy="50" r="8" fill="#1F2937"/>
                <circle cx="30" cy="50" r="4" fill="#6B7280"/>
                <circle cx="70" cy="50" r="4" fill="#6B7280"/>
                <!-- Suction effect -->
                <line x1="-8" y1="98" x2="-20" y2="86" stroke="#FAF8F5" stroke-width="1.5" stroke-dasharray="3 2" opacity="0.7"/>
                <line x1="-2" y1="98" x2="-6" y2="82" stroke="#FAF8F5" stroke-width="1.5" stroke-dasharray="3 2" opacity="0.7"/>
                <line x1="4" y1="98" x2="8" y2="83" stroke="#FAF8F5" stroke-width="1.5" stroke-dasharray="3 2" opacity="0.7"/>
              </g>
            </svg>
          </div>
        </div>

        <div class="err-text">
          <span class="err-code">404</span>
          <h1 class="err-title">Αυτή η σελίδα<br>ρουφήχτηκε από<br>την ηλεκτρική!</h1>
          <p class="err-desc">
            Ψάχνεις για κάτι που δεν βρέθηκε. Μπορεί η σελίδα να μετακόμισε, να μετονομάστηκε ή απλά να χρειάζεται ένα καλό πλύσιμο.
          </p>
          <p class="err-desc err-desc--small">
            Μη στεναχωριέσαι όμως — τα χαλιά μας τα βρίσκουμε πάντα. Τις σελίδες... μερικές φορές όχι.
          </p>
          <div class="err-actions">
            <a href="/" class="btn btn--primary">Πήγαινε στην Αρχική</a>
            <a href="/epikoinonia/" class="btn btn--outline">Επικοινωνία</a>
          </div>
          <div class="err-links">
            <p>Ή δες μια από τις σελίδες μας:</p>
            <ul>
              <li><a href="/katharismos-xaliwn/">Καθαρισμός Χαλιών</a></li>
              <li><a href="/prosfores/">Προσφορές</a></li>
              <li><a href="/etairia/">Η Εταιρία μας</a></li>
              <li><a href="/syxnes-erotiseis/">Συχνές Ερωτήσεις</a></li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-404 {
    background: var(--color-bg);
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: var(--space-16) 0;
  }
  .err-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .err-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .rug-wrapper {
    width: 100%;
    max-width: 420px;
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .rug-svg {
    width: 100%;
    height: auto;
    drop-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .err-code {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }
  .err-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .err-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: var(--space-3);
  }
  .err-desc--small {
    font-size: var(--text-sm);
    font-style: italic;
    margin-bottom: var(--space-6);
  }
  .err-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }
  .err-links p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
  .err-links ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .err-links ul li::before {
    content: '→ ';
    color: var(--color-primary);
  }
  .err-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .err-links a:hover { color: var(--color-primary); }

  @media (max-width: 700px) {
    .err-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      text-align: center;
    }
    .err-desc, .err-links ul {
      margin-inline: auto;
    }
    .err-actions {
      justify-content: center;
    }
    .rug-wrapper {
      max-width: 280px;
      margin-inline: auto;
    }
  }
</style>
