---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ | Χειροποίητο Πλύσιμο Ταπήτων από το 1980"
  description="Χειροποίητο ριζικό πλύσιμο ταπήτων στην Αττική από το 1980. Δωρεάν παραλαβή & παράδοση. 45+ χρόνια εμπειρίας. Καλέστε 210 27 76 365."
>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content container">
      <div class="hero-badge">Από το 1980 · Β΄ Γενιά Εξειδίκευσης</div>
      <h1 class="hero-title">Χειροποίητο Ριζικό<br>Πλύσιμο Ταπήτων</h1>
      <p class="hero-subtitle">Πρωτοπόρα στον υγρό καθαρισμό ταπήτων στο λεκανοπέδιο Αττικής. Εμπιστευτείτε τα χαλιά σας σε χέρια ειδικών.</p>
      <div class="hero-actions">
        <a href="tel:+302102776365" class="btn btn--primary btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          210 27 76 365
        </a>
        <a href="/epikoinonia" class="btn btn--outline btn--lg">Ζητήστε Παραλαβή</a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="trust-strip">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item reveal">
          <span class="trust-number">45+</span>
          <span class="trust-label">Χρόνια Εμπειρίας</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item reveal">
          <span class="trust-number">2η</span>
          <span class="trust-label">Γενιά Εξειδίκευσης</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item reveal">
          <span class="trust-number">800</span>
          <span class="trust-label">τ.μ. Εγκαταστάσεις</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item reveal">
          <span class="trust-number">Δωρεάν</span>
          <span class="trust-label">Παραλαβή & Παράδοση*</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section (NEW) -->
  <section class="about-section section-padding">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <span class="section-label">Σχετικά με Εμάς</span>
          <p class="about-motto">«Είναι καθαρά... στο χέρι μας!!!»</p>
          <p class="about-desc">Τα Ταπητοκαθαριστήρια ΔΑΜΙΑΝΟΣ λειτουργούν από το 1980, πρωτοπόρα στον υγρό καθαρισμό ταπήτων. Με δύο γενιές εξειδίκευσης και αγάπη για την τέχνη του πλυσίματος ταπήτων, προσφέρουμε χειροποίητο ριζικό πλύσιμο σε κάθε χαλί — ανεξαρτήτως αξίας και παλαιότητας.</p>
          <a href="/etairia" class="btn btn--primary">Μάθετε Περισσότερα</a>
        </div>
        <div class="about-image reveal">
          <img src="/images/process-machine.jpg" alt="Περιστροφική μηχανή καθαρισμού χαλιού στο εργαστήριο ΔΑΜΙΑΝΟΣ" loading="lazy" width="600" height="450">
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="video-section">
    <div class="container">
      <div class="video-wrapper reveal">
        <video autoplay muted loop playsinline preload="metadata" poster="/images/process-splash-1.jpg">
          <source src="/images/damianos-process.mp4" type="video/mp4">
        </video>
        <div class="video-overlay">
          <p class="video-caption">Δείτε τη διαδικασία καθαρισμού στις εγκαταστάσεις μας</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Before / After Section -->
  <section class="ba-section section-padding">
    <div class="container">
      <div class="ba-header reveal">
        <span class="section-label">Το Αποτέλεσμα</span>
        <h2 class="section-title">Πριν & Μετά τον Καθαρισμό</h2>
        <p class="ba-subtitle">Σύρετε τον διαχωριστή για να δείτε τη διαφορά</p>
        <hr class="divider">
      </div>

      <div class="ba-slider-wrapper reveal">
        <div class="ba-slider" data-ba-slider>
          <div class="ba-image ba-image--after">
            <img src="/images/after-1.jpg" alt="Τάπητας μετά τον καθαρισμό" loading="lazy" width="540" height="591">
            <span class="ba-label ba-label--after">Μετά</span>
          </div>
          <div class="ba-image ba-image--before">
            <img src="/images/before-1.jpg" alt="Τάπητας πριν τον καθαρισμό" loading="lazy" width="540" height="591">
            <span class="ba-label ba-label--before">Πριν</span>
          </div>
          <div class="ba-handle" aria-label="Μετακίνηση διαχωριστή">
            <div class="ba-handle-line"></div>
            <div class="ba-handle-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </div>
            <div class="ba-handle-line"></div>
          </div>
        </div>
      </div>

      <div class="ba-thumbnails reveal">
        <button class="ba-thumb active" data-before="/images/before-1.jpg" data-after="/images/after-1.jpg" aria-label="Δείγμα 1">
          <img src="/images/ba-rug-1.jpg" alt="Δείγμα καθαρισμού 1" loading="lazy" width="120" height="66">
        </button>
        <button class="ba-thumb" data-before="/images/before-2.jpg" data-after="/images/after-2.jpg" aria-label="Δείγμα 2">
          <img src="/images/ba-rug-2.jpg" alt="Δείγμα καθαρισμού 2" loading="lazy" width="120" height="60">
        </button>
        <button class="ba-thumb" data-before="/images/before-3.jpg" data-after="/images/after-3.jpg" aria-label="Δείγμα 3">
          <img src="/images/ba-rug-3.jpg" alt="Δείγμα καθαρισμού 3" loading="lazy" width="120" height="66">
        </button>
      </div>
    </div>
  </section>

  <!-- Values Section (Staggered) -->
  <section class="values section-padding">
    <div class="container">
      <div class="values-header reveal">
        <span class="section-label">Οι Αξίες Μας</span>
        <h2 class="section-title">Γιατί Να Μας Εμπιστευτείτε</h2>
        <hr class="divider">
      </div>

      <div class="values-grid">
        <div class="value-card value-card--1 reveal">
          <span class="value-number">01</span>
          <h3 class="value-title">Σεβασμός σε Κάθε Τάπητα</h3>
          <p>Ο καθαρισμός όλων των ταπήτων γίνεται με σεβασμό και επίδειξη της ίδιας μεγάλης προσοχής, ανεξαρτήτως αξίας και παλαιότητας.</p>
        </div>
        <div class="value-card value-card--2 reveal">
          <span class="value-number">02</span>
          <h3 class="value-title">Χειροποίητο Ριζικό Πλύσιμο</h3>
          <p>Συνειδητή επιλογή χειροποίητου ριζικού πλυσίματος, ώστε να επιτυγχάνεται ο εις βάθος καθαρισμός, σωστή συντήρηση, υγιεινή και μακροζωία.</p>
        </div>
        <div class="value-card value-card--3 reveal">
          <span class="value-number">03</span>
          <h3 class="value-title">Ολοκληρωμένη Εξυπηρέτηση</h3>
          <p>Υψηλού επιπέδου υπηρεσίες παραλαβής, φύλαξης και παράδοσης, με απόλυτη ασφάλεια και συνέπεια σε όλο το λεκανοπέδιο Αττικής.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="services-preview">
    <div class="services-image-band">
      <img src="/images/textile-pattern.jpg" alt="Παραδοσιακή υφαντική τέχνη" loading="lazy" width="1920" height="600">
    </div>
    <div class="container">
      <div class="services-content reveal">
        <span class="section-label">Οι Υπηρεσίες Μας</span>
        <h2 class="section-title">Ολοκληρωμένες Υπηρεσίες Φροντίδας Ταπήτων</h2>
        <hr class="divider">
      </div>

      <div class="services-grid">
        <a href="/katharismos-xaliwn" class="service-preview-card reveal">
          <div class="service-icon">
            <!-- Water droplets icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
            </svg>
          </div>
          <h3>Καθαρισμός Χαλιών</h3>
          <p>Χειρονακτικός υγρός καθαρισμός με παραδοσιακές μεθόδους</p>
        </a>

        <a href="/fylaksi-tapiton" class="service-preview-card reveal">
          <div class="service-icon">
            <!-- Shield icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Φύλαξη Ταπήτων</h3>
          <p>Ασφαλής φύλαξη σε ιδιόκτητες εγκαταστάσεις 800 τ.μ.</p>
        </a>

        <a href="/episkeves-xalion" class="service-preview-card reveal">
          <div class="service-icon">
            <!-- Scissors icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/>
              <line x1="20" y1="4" x2="8.12" y2="15.88"/>
              <line x1="14.47" y1="14.48" x2="20" y2="20"/>
              <line x1="8.12" y1="8.12" x2="12" y2="12"/>
            </svg>
          </div>
          <h3>Επισκευές Χαλιών</h3>
          <p>Αλλαγή ρελιών, κροσιών, μπαλώματα, κοψίματα</p>
        </a>

        <a href="/paralavi-paradosi" class="service-preview-card service-preview-card--wide reveal">
          <div class="service-icon">
            <!-- Truck icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <h3>Παραλαβή & Παράδοση</h3>
          <p>Δωρεάν μεταφορά με ιδιόκτητα μέσα σε όλη την Αττική</p>
        </a>

        <a href="/plysimo-paplomaton" class="service-preview-card reveal">
          <div class="service-icon">
            <!-- Sparkles / wind icon -->
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>
              <path d="M20 3v4"/><path d="M22 5h-4"/>
            </svg>
          </div>
          <h3>Παπλώματα & Κουβέρτες</h3>
          <p>Χειρονακτικός καθαρισμός χωρίς χημικά, πραγματική φρεσκάδα</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Tips Section (NEW) -->
  <section class="tips-section section-padding">
    <div class="container">
      <div class="tips-header reveal">
        <span class="section-label">Χρήσιμες Συμβουλές</span>
        <h2 class="section-title">Συμβουλές για τα Χαλιά σας</h2>
        <hr class="divider">
      </div>

      <div class="tips-grid">
        <div class="tip-card reveal">
          <div class="tip-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <h3 class="tip-title">Τσίχλα στο χαλί;</h3>
          <p>Βάλτε παγάκια σε σακούλα πάνω στην τσίχλα μέχρι να σκληρύνει. Μετά αφαιρέστε τη προσεκτικά.</p>
        </div>
        <div class="tip-card reveal">
          <div class="tip-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/>
            </svg>
          </div>
          <h3 class="tip-title">Λεκές από καφέ;</h3>
          <p>Σκουπίστε αμέσως με χαρτί κουζίνας. Μη τρίβετε — πιέστε απαλά. Ξεβγάλτε με κρύο νερό.</p>
        </div>
        <div class="tip-card reveal">
          <div class="tip-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5c0-2-1.5-3.5-3-5L12 3l-2 2c-1.5 1.5-3 3-3 5a5 5 0 0 0 5 5z"/>
            </svg>
          </div>
          <h3 class="tip-title">Λεκές από κρασί;</h3>
          <p>Ρίξτε αμέσως αλάτι πάνω στον λεκέ για να απορροφηθεί. Μετά ξεβγάλτε με κρύο νερό.</p>
        </div>
        <div class="tip-card reveal">
          <div class="tip-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.91 8.84 8.56 21.16a1.5 1.5 0 0 1-2.12 0L3.8 18.52a1.5 1.5 0 0 1 0-2.12L16.12 4.06"/><path d="M21 3 9 15"/>
              <path d="M3.59 10.42 10 4"/><path d="M14 20.42 20.41 14"/>
            </svg>
          </div>
          <h3 class="tip-title">Πώς αποθηκεύω τα χαλιά;</h3>
          <p>Πάντα καθαρά και στεγνά, τυλιγμένα σε νάιλον, σε δροσερό χώρο μακριά από υγρασία.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    background-image: url('/images/process-splash-1.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(31, 41, 55, 0.82) 0%, rgba(31, 41, 55, 0.55) 60%, rgba(181, 55, 42, 0.25) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-24) var(--space-16);
    max-width: 680px;
  }
  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(200, 169, 110, 0.2);
    border: 1px solid rgba(200, 169, 110, 0.4);
    border-radius: var(--radius-lg);
    color: var(--color-gold-light);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-6);
  }
  .hero-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: #FFFFFF;
    margin-bottom: var(--space-6);
    line-height: 1.08;
  }
  .hero-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
    margin-bottom: var(--space-8);
    max-width: 52ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero-actions .btn--outline {
    border-color: rgba(255,255,255,0.5);
    color: #FFFFFF;
  }
  .hero-actions .btn--outline:hover {
    background: rgba(255,255,255,0.1);
    border-color: #FFFFFF;
  }

  /* ===== Trust Strip ===== */
  .trust-strip {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-10);
  }
  .trust-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-1);
  }
  .trust-number {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
  }
  .trust-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .trust-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }
  @media (max-width: 600px) {
    .trust-grid { gap: var(--space-6); }
    .trust-divider { display: none; }
    .trust-grid { display: grid; grid-template-columns: 1fr 1fr; }
  }

  /* ===== About Section ===== */
  .about-section {
    background: var(--color-surface);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .about-motto {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
    line-height: 1.3;
    font-weight: 500;
  }
  .about-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-8);
    max-width: 56ch;
  }
  .about-image {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
  }
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .about-image { order: -1; }
  }

  /* ===== Video Section ===== */
  .video-section {
    padding: var(--space-8) 0;
    background: var(--color-bg);
  }
  .video-wrapper {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    max-height: 500px;
  }
  .video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6) var(--space-8);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
  }
  .video-caption {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: #fff;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ===== Values ===== */
  .values { background: var(--color-cream); }
  .values-header { margin-bottom: var(--space-12); }
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .value-card {
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    border-top: 3px solid var(--color-primary);
  }
