---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Carpet Cleaning",
  "provider": {
    "@type": "LocalBusiness",
    "name": "ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Αττική, Ελλάδα"
  },
  "description": "Χειροποίητο ριζικό πλύσιμο ταπήτων, φύλαξη, επισκευές, παραλαβή & παράδοση"
};
---

<BaseLayout
  title="Υπηρεσίες Καθαρισμού Ταπήτων | ΔΑΜΙΑΝΟΣ – Πλύσιμο, Φύλαξη, Επισκευές"
  description="Ολοκληρωμένες υπηρεσίες φροντίδας ταπήτων: χειροποίητο πλύσιμο, φύλαξη, επισκευές, παραλαβή-παράδοση, καθαρισμός παπλωμάτων."
  jsonLd={serviceSchema}
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Υπηρεσίες</span>
      <h1 class="page-hero-title">Ολοκληρωμένες Υπηρεσίες<br>Φροντίδας Ταπήτων</h1>
      <p class="page-hero-subtitle">Από τον καθαρισμό μέχρι τη φύλαξη και τις επισκευές — καλύπτουμε κάθε ανάγκη του χαλιού σας.</p>
    </div>
  </section>

  <!-- Services Accordion -->
  <section class="services-section section-padding">
    <div class="container">

      <!-- 1. Καθαρισμός Ταπήτων (open by default) -->
      <div class="svc-accordion svc-accordion--open reveal" data-accordion id="katharismos">
        <button class="svc-accordion-trigger" aria-expanded="true">
          <div class="svc-trigger-left">
            <span class="svc-number">01</span>
            <div>
              <h2 class="svc-title">Καθαρισμός Ταπήτων</h2>
              <p class="svc-brief">Χειρονακτικός υγρός καθαρισμός με παραδοσιακές μεθόδους</p>
            </div>
          </div>
          <svg class="svc-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="svc-accordion-body">
          <div class="svc-intro">
            <p>Ο καθαρισμός χαλιών γίνεται αυστηρά με χειρονακτικό τρόπο, σύμφωνα με τις παραδοσιακές μεθόδους που διδαχθήκαμε από τους παλαιότερους συναδέλφους μας. Τα χαλιά πλένονται ριζικά με άφθονο νερό, που διοχετεύεται στο χαλί και από την κάτω του πλευρά, ώστε η σκόνη και η βρώμα να αποβάλλονται εις βάθος και όχι απλά επιφανειακά.</p>
          </div>

          <h3 class="svc-subtitle">Η Διαδικασία Βήμα-Βήμα</h3>
          <div class="process-steps">
            <div class="process-step">
              <div class="step-number">1</div>
              <div class="step-content">
                <h4>Σαπούνισμα</h4>
                <p>Χρήση ειδικής σκόνης σαπουνιού, ιδανικής για όλους τους τύπους ταπήτων και ανάδειξη χρωμάτων.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">2</div>
              <div class="step-content">
                <h4>Τρίψιμο</h4>
                <p>Χειροκίνητη περιστροφική μηχανή με ειδική βούρτσα — επιμονή στα πιο «ταλαιπωρημένα» σημεία.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">3</div>
              <div class="step-content">
                <h4>Ξέβγαλμα</h4>
                <p>Σχολαστικό ξέβγαλμα με χρήση κέλμπερι (παραδοσιακό χειροκίνητο εργαλείο) που «χτενίζει» τον πέλο και ισιώνει τσαλακώματα.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">4</div>
              <div class="step-content">
                <h4>Καθαρισμός Κροσιών</h4>
                <p>Πιεστικό μηχάνημα νερού (χωρίς χημικά) για κάθε λεπτομέρεια στα κρόσια.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">5</div>
              <div class="step-content">
                <h4>Στύψιμο</h4>
                <p>Σύγχρονο φυγοκεντρικό μηχάνημα — αποφυγή ξεβαμμάτων, διατήρηση ζωντανών χρωμάτων.</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">6</div>
              <div class="step-content">
                <h4>Στέγνωμα</h4>
                <p>Φυσικά αεριζόμενος στεγασμένος χώρος, μακριά από ηλιακές ακτίνες.</p>
              </div>
            </div>
          </div>

          <p class="process-note">Το τέλειο αποτέλεσμα επιτυγχάνεται μόνο από εξειδικευμένη ανθρώπινη προσπάθεια, με χειρονακτικό τρόπο.</p>

          <!-- Pricing CTA inside cleaning service -->
          <div class="svc-pricing-cta">
            <div class="svc-pricing-card svc-pricing-card--main">
              <span class="svc-pricing-badge">Κύρια Υπηρεσία</span>
              <h4>Ριζικό Πλύσιμο Χειροποίητων Χαλιών</h4>
              <p>Χειρονακτικός υγρός καθαρισμός με παραδοσιακές μεθόδους. Περιλαμβάνει σαπούνισμα, τρίψιμο, ξέβγαλμα, καθαρισμό κροσιών, στύψιμο και στέγνωμα.</p>
              <div class="svc-pricing-price">
                <span class="svc-pricing-from">Από</span>
                <span class="svc-pricing-amount">8€</span>
                <span class="svc-pricing-unit">/τ.μ.*</span>
              </div>
              <a href="tel:+302102776365" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Καλέστε για Εκτίμηση
              </a>
            </div>
            <div class="svc-pricing-extras">
              <div class="svc-pricing-card svc-pricing-card--small">
                <h4>Πλύσιμο Κουβέρτας</h4>
                <p>Μονή / Διπλή</p>
                <div class="svc-pricing-price">
                  <span class="svc-pricing-amount svc-pricing-amount--sm">15€</span>
                  <span class="svc-pricing-unit">/τεμ. + ΦΠΑ</span>
                </div>
              </div>
              <div class="svc-pricing-card svc-pricing-card--small">
                <h4>Πλύσιμο Παπλώματος</h4>
                <p>Μονό / Διπλό</p>
                <div class="svc-pricing-price">
                  <span class="svc-pricing-amount svc-pricing-amount--sm">18€</span>
                  <span class="svc-pricing-unit">/τεμ. + ΦΠΑ</span>
                </div>
              </div>
            </div>
            <p class="svc-pricing-note">* Στην τιμή δεν συμπεριλαμβάνεται ΦΠΑ 24%</p>
          </div>
        </div>
      </div>

      <!-- 2. Φύλαξη Ταπήτων -->
      <div class="svc-accordion reveal" data-accordion id="fylaksi">
        <button class="svc-accordion-trigger" aria-expanded="false">
          <div class="svc-trigger-left">
            <span class="svc-number">02</span>
            <div>
              <h2 class="svc-title">Φύλαξη Ταπήτων</h2>
              <p class="svc-brief">Ασφαλής φύλαξη σε ιδιόκτητες εγκαταστάσεις 800 τ.μ.</p>
            </div>
          </div>
          <svg class="svc-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="svc-accordion-body">
          <p>Η φύλαξη των ταπήτων γίνεται στις σύγχρονες ιδιόκτητες εγκαταστάσεις μας στο Νέο Ηράκλειο. Τα χαλιά είναι απολύτως ασφαλή και φυλάσσονται σε ειδικά ράφια μέσα σε νάιλον θήκη, κάτω από τις καταλληλότερες συνθήκες.</p>

          <div class="svc-highlight">
            <strong>Δωρεάν φύλαξη</strong> σε συνδυασμό με τον καθαρισμό, μέχρι τις 31 Δεκεμβρίου του έτους που παραδόθηκαν σε εμάς.
          </div>

          <p>Μετά την παρέλευση της συγκεκριμένης ημερομηνίας και την υποχρεωτική εξόφληση του λογαριασμού καθαρισμού τους, υπολογίζονται χρεωστικά φυλάξεως (ισχύουσα τιμή / τετραγωνικό μέτρο + Φ.Π.Α.).</p>

          <div class="svc-features">
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Ειδικά ράφια αποθήκευσης</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Νάιλον θήκη προστασίας</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Κατάλληλες συνθήκες θερμοκρασίας & υγρασίας</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>800 τ.μ. ιδιόκτητες εγκαταστάσεις</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. Επισκευές Χαλιών -->
      <div class="svc-accordion reveal" data-accordion id="episkeves">
        <button class="svc-accordion-trigger" aria-expanded="false">
          <div class="svc-trigger-left">
            <span class="svc-number">03</span>
            <div>
              <h2 class="svc-title">Επισκευές Χαλιών</h2>
              <p class="svc-brief">Αλλαγή ρελιών, κροσιών, μπαλώματα, κοψίματα</p>
            </div>
          </div>
          <svg class="svc-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="svc-accordion-body">
          <p>Η επιχείρησή μας αναλαμβάνει κάθε είδους επισκευή-επιδιόρθωση σε μηχανοποίητα χαλιά και μοκέτες.</p>

          <h3 class="svc-subtitle">Μηχανοποίητα Χαλιά & Μοκέτες</h3>
          <ul class="svc-list">
            <li>Αλλαγή ρελιών (μάλλινο ή νάιλον)</li>
            <li>Αλλαγή κροσιών (ποικιλία σε σχέδια, ποιότητες και αποχρώσεις)</li>
            <li>Κόψιμο ταπήτων στο επιθυμητό μέγεθος</li>
            <li>Μπάλωμα με θερμοκόλληση</li>
          </ul>

          <h3 class="svc-subtitle">Χειροποίητα Χαλιά</h3>
          <ul class="svc-list">
            <li>Αντικατάσταση κροσιών</li>
            <li>Επισκευή σε διαφόρων ειδών φθορές</li>
            <li>Αποκατάσταση ζημιών από φθορά χρήσης ή σκόρο</li>
          </ul>
        </div>
      </div>

      <!-- 4. Παραλαβή & Παράδοση -->
      <div class="svc-accordion reveal" data-accordion id="paralavi">
        <button class="svc-accordion-trigger" aria-expanded="false">
          <div class="svc-trigger-left">
            <span class="svc-number">04</span>
            <div>
              <h2 class="svc-title">Παραλαβή & Παράδοση</h2>
              <p class="svc-brief">Δωρεάν μεταφορά με ιδιόκτητα μέσα σε όλη την Αττική</p>
            </div>
          </div>
          <svg class="svc-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="svc-accordion-body">
          <p>Η παραλαβή και παράδοση των ταπήτων γίνεται με ιδιόκτητα μεταφορικά μέσα, κατόπιν ραντεβού και στο συντομότερο δυνατόν χρόνο από τη στιγμή της ειδοποίησής σας.</p>

          <div class="delivery-grid">
            <div class="delivery-card">
              <span class="delivery-tag delivery-tag--green">Υψηλή Κίνηση</span>
              <h4>Απρίλιος – Δεκέμβριος</h4>
              <p>Δωρεάν μεταφορά σε μαζικά δρομολόγια σε όλο το λεκανοπέδιο Αττικής.</p>
            </div>
            <div class="delivery-card">
              <span class="delivery-tag delivery-tag--muted">Χαμηλή Κίνηση</span>
              <h4>Ιανουάριος – Μάρτιος</h4>
              <p>Ενδέχεται μεταφορικά έξοδα, που ποικίλουν ανάλογα την απόσταση από την έδρα μας.</p>
            </div>
          </div>

          <div class="svc-cta-inline">
            <p>Κλείστε ραντεβού παραλαβής τηλεφωνικά:</p>
            <a href="tel:+302102776365" class="btn btn--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              210 27 76 365
            </a>
          </div>
        </div>
      </div>

      <!-- 5. Παπλώματα & Κουβέρτες -->
      <div class="svc-accordion reveal" data-accordion id="paplomata">
        <button class="svc-accordion-trigger" aria-expanded="false">
          <div class="svc-trigger-left">
            <span class="svc-number">05</span>
            <div>
              <h2 class="svc-title">Πλύσιμο Παπλωμάτων & Κουβερτών</h2>
              <p class="svc-brief">Χειρονακτικός καθαρισμός χωρίς χημικά, πραγματική φρεσκάδα</p>
            </div>
          </div>
          <svg class="svc-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="svc-accordion-body">
          <p>Η επιχείρησή μας αναλαμβάνει τον υγρό καθαρισμό των κουβερτών και παπλωμάτων σας. Η διαδικασία γίνεται, όπως και στους τάπητες, αυστηρά με χειρονακτικό τρόπο, απουσία πλυντηρίων και οποιασδήποτε χημικής επεξεργασίας.</p>
          <p>Αποφεύγονται οσμές του στεγνού καθαρισμού και τα αγαπημένα σας κλινοσκεπάσματα επιστρέφονται σε εσάς και την οικογένειά σας, απολύτως καθαρά και υγιεινά, μυρίζοντας πραγματική φρεσκάδα.</p>

          <div class="svc-features">
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Χωρίς πλυντήρια</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Χωρίς χημικά</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>100% χειρονακτικός καθαρισμός</span>
            </div>
            <div class="svc-feature">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-sage)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Πραγματική φρεσκάδα</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--color-cream);
    padding: var(--space-24) 0 var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }
  .page-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.65;
  }

  /* ===== Accordion ===== */
  .services-section {
    background: var(--color-bg);
  }
  .svc-accordion {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    margin-bottom: var(--space-4);
    overflow: hidden;
    transition: box-shadow var(--transition-fast);
  }
  .svc-accordion:hover {
    box-shadow: var(--shadow-sm);
  }

  .svc-accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-8);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: var(--space-4);
  }
  .svc-trigger-left {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-width: 0;
  }
  .svc-number {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-cream);
    line-height: 1;
  }
  .svc-accordion--open .svc-number,
  .svc-accordion:hover .svc-number {
    color: var(--color-primary);
    opacity: 0.3;
  }
  .svc-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .svc-brief {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .svc-chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
  }
  .svc-accordion--open .svc-chevron {
    transform: rotate(180deg);
  }

  /* Accordion body */
  .svc-accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    padding: 0 var(--space-8);
  }
  .svc-accordion--open .svc-accordion-body {
    max-height: 3000px;
    padding: 0 var(--space-8) var(--space-8);
  }

  .svc-accordion-body > p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-4);
    max-width: 72ch;
  }
  .svc-intro p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-6);
    max-width: 72ch;
