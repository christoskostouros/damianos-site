---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const cmsEntry = await getEntry('pages', 'offers');
const cms = (cmsEntry?.data ?? {}) as any;
---

<BaseLayout
  title={cms.seoTitle || "Προσφορές & Τιμές Πλυσίματος Ταπήτων | ΔΑΜΙΑΝΟΣ"}
  description={cms.seoDescription || "Τιμές πλυσίματος χαλιών από 8€/τ.μ. Πλύσιμο κουβερτών 15€, παπλωμάτων 18€. Δωρεάν φύλαξη με καθαρισμό. Καλέστε 210 27 76 365."}
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Τιμοκατάλογος</span>
      <h1 class="page-hero-title">Προσφορές & Τιμές</h1>
      <p class="page-hero-subtitle">Ποιοτικός καθαρισμός σε ανταγωνιστικές τιμές. Ζητήστε δωρεάν εκτίμηση.</p>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing section-padding">
    <div class="container">

      <!-- Main Offer -->
      <div class="pricing-main reveal">
        <div class="pricing-main-badge">Προσφορά</div>
        <div class="pricing-main-content">
          <h2 class="pricing-main-title">Ριζικό Πλύσιμο Χειροποίητων Χαλιών</h2>
          <p class="pricing-main-desc">Χειρονακτικός υγρός καθαρισμός με παραδοσιακές μεθόδους. Περιλαμβάνει σαπούνισμα, τρίψιμο, ξέβγαλμα, καθαρισμό κροσιών, στύψιμο και στέγνωμα.</p>
          <div class="pricing-main-price">
            <span class="price-from">Από</span>
            <span class="price-amount">{cms.priceRug || "8"}€</span>
            <span class="price-unit">/τ.μ.*</span>
          </div>
          <a href="tel:+302102776365" class="btn btn--primary btn--lg">Καλέστε για Εκτίμηση</a>
        </div>
      </div>

      <!-- Other Prices -->
      <div class="pricing-grid">
        <div class="pricing-card reveal">
          <div class="pricing-card-header">
            <h3>Πλύσιμο Κουβέρτας</h3>
            <span class="pricing-card-size">Μονή / Διπλή</span>
          </div>
          <div class="pricing-card-price">
            <span class="price-amount-sm">{cms.priceBlanket || "15"}€</span>
            <span class="price-unit-sm">/τεμάχιο + ΦΠΑ</span>
          </div>
          <p>Χειρονακτικός υγρός καθαρισμός χωρίς πλυντήρια και χημικά.</p>
        </div>

        <div class="pricing-card reveal">
          <div class="pricing-card-header">
            <h3>Πλύσιμο Παπλώματος</h3>
            <span class="pricing-card-size">Μονό / Διπλό</span>
          </div>
          <div class="pricing-card-price">
            <span class="price-amount-sm">{cms.priceDuvet || "18"}€</span>
            <span class="price-unit-sm">/τεμάχιο + ΦΠΑ</span>
          </div>
          <p>Επιστρέφεται απολύτως καθαρό, υγιεινό, με πραγματική φρεσκάδα.</p>
        </div>
      </div>

      <!-- Footnote -->
      <div class="pricing-footnote reveal">
        <p>*Στην τιμή δεν συμπεριλαμβάνεται ΦΠΑ 24%</p>
        <p>Για ενημέρωση σε προσφορές και εκπτώσεις:</p>
        <div class="footnote-contact">
          <a href="tel:+302102776365" class="footnote-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            210 27 76 365
          </a>
          <span class="footnote-sep">–</span>
          <a href="tel:+302102798261" class="footnote-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            210 27 98 261
          </a>
          <span class="footnote-sep">–</span>
          <a href="mailto:info@plisimotapiton.gr" class="footnote-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            info@plisimotapiton.gr
          </a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--color-cream);
    padding: var(--space-24) 0 var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }
  .page-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.65;
  }

  /* Main Offer Card */
  .pricing-main {
    position: relative;
    background: var(--color-surface);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-xl);
    padding: var(--space-10) var(--space-8);
    margin-bottom: var(--space-8);
    overflow: hidden;
  }
  .pricing-main::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle at top right, rgba(26, 75, 140, 0.06) 0%, transparent 70%);
  }
  .pricing-main-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-primary);
    color: #FFFFFF;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-6);
  }
  .pricing-main-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }
  .pricing-main-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 56ch;
    margin-bottom: var(--space-6);
  }
  .pricing-main-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .price-from {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  .price-unit {
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  /* Other cards */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }
  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .pricing-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .pricing-card-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
  }
  .pricing-card-size {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-cream);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .pricing-card-price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .price-amount-sm {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .price-unit-sm {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .pricing-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Footnote */
  .pricing-footnote {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }
  .pricing-footnote p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
  .pricing-footnote p:first-child {
    font-style: italic;
  }
  .footnote-contact {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
  }
  .footnote-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .footnote-link:hover { color: var(--color-primary-hover); }
  .footnote-sep { color: var(--color-border-dark); }

  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-main { padding: var(--space-6); }
    .footnote-contact { flex-direction: column; align-items: flex-start; }
    .footnote-sep { display: none; }
  }
</style>
