---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Carpet Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Αττική, Ελλάδα"
  },
  "description": "Κάθε είδους επισκευή-επιδιόρθωση σε μηχανοποίητα και χειροποίητα χαλιά. Αλλαγή ρελιών, κροσιών, κοψίματα, θερμοκόλληση."
};
---

<BaseLayout
  title="Επισκευές Χαλιών | ΔΑΜΙΑΝΟΣ – Αλλαγή Ρελιών, Κροσιών, Μπαλώματα"
  description="Κάθε είδους επισκευή-επιδιόρθωση σε μηχανοποίητα και χειροποίητα χαλιά. Αλλαγή ρελιών, κροσιών, κοψίματα, θερμοκόλληση."
  jsonLd={serviceSchema}
>

  <section class="page-hero">
    <div class="container">
      <span class="section-label">Υπηρεσίες</span>
      <h1 class="page-hero-title">Επισκευές Χαλιών</h1>
      <p class="page-hero-subtitle">Αλλαγή ρελιών, κροσιών, μπαλώματα, κοψίματα — για μηχανοποίητα και χειροποίητα χαλιά.</p>
    </div>
  </section>

  <section class="svc-page section-padding">
    <div class="container">
      <p class="svc-text">Η επιχείρησή μας αναλαμβάνει κάθε είδους επισκευή-επιδιόρθωση σε μηχανοποίητα χαλιά και μοκέτες.</p>

      <h2 class="svc-subtitle">Μηχανοποίητα Χαλιά & Μοκέτες</h2>
      <ul class="svc-list">
        <li>Αλλαγή ρελιών (μάλλινο ή νάιλον)</li>
        <li>Αλλαγή κροσιών (ποικιλία σε σχέδια, ποιότητες και αποχρώσεις)</li>
        <li>Κόψιμο ταπήτων στο επιθυμητό μέγεθος</li>
        <li>Μπάλωμα με θερμοκόλληση</li>
      </ul>

      <h2 class="svc-subtitle">Χειροποίητα Χαλιά</h2>
      <ul class="svc-list">
        <li>Αντικατάσταση κροσιών</li>
        <li>Επισκευή σε διαφόρων ειδών φθορές</li>
      </ul>

      <div class="svc-cta-inline">
        <p>Κλείστε ραντεβού τηλεφωνικά:</p>
        <a href="tel:+302102776365" class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          210 27 76 365
        </a>
        <a href="tel:+302102798261" class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          210 27 98 261
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    background: var(--color-cream);
    padding: var(--space-24) 0 var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }
  .page-hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.65;
  }

  .svc-page {
    background: var(--color-bg);
  }

  .svc-text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-4);
    max-width: 72ch;
  }

  .svc-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    margin-top: var(--space-6);
    color: var(--color-text);
  }

  .svc-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .svc-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-left: var(--space-5);
    position: relative;
    line-height: 1.6;
  }
  .svc-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .svc-cta-inline {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }
  .svc-cta-inline p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .svc-cta-inline { flex-direction: column; align-items: flex-start; }
  }
</style>
