  <!-- JSON-LD: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessLd)} />

  <!-- Page-specific JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
