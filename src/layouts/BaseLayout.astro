---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, canonical, ogImage = '/images/hero-rug.jpg', jsonLd } = Astro.props;
const siteUrl = 'https://damianos-site.netlify.app';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;

const navItems = [
  { label: 'Αρχική', href: '/' },
  { label: 'Εταιρία', href: '/etairia' },
  { label: 'Υπηρεσίες', href: '/katharismos-xaliwn', children: [
    { label: 'Καθαρισμός Χαλιών', href: '/katharismos-xaliwn' },
    { label: 'Φύλαξη Ταπήτων', href: '/fylaksi-tapiton' },
    { label: 'Επισκευές Χαλιών', href: '/episkeves-xalion' },
    { label: 'Παραλαβή & Παράδοση', href: '/paralavi-paradosi' },
    { label: 'Παπλώματα & Κουβέρτες', href: '/plysimo-paplomaton' },
  ]},
  { label: 'Προσφορές', href: '/prosfores' },
  { label: 'Ερωτήσεις', href: '/syxnes-erotiseis' },
  { label: 'Επικοινωνία', href: '/epikoinonia' },
  { label: 'Ιστορία Χαλιού', href: '/istoria-xaliou' },
];

const currentPath = Astro.url.pathname;

// LocalBusiness JSON-LD (every page)
const localBusinessLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ",
  "alternateName": "Damianos Carpet Cleaning",
  "description": "Χειροποίητο ριζικό πλύσιμο ταπήτων από το 1980. Πρωτοπόρα στον υγρό καθαρισμό χαλιών στην Αττική.",
  "url": siteUrl,
  "telephone": ["+302102776365", "+302102798261"],
  "email": "info@plisimotapiton.gr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Σαρανταπόρου 27",
    "addressLocality": "Νέο Ηράκλειο",
    "postalCode": "141-21",
    "addressRegion": "Αττική",
    "addressCountry": "GR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.0487,
    "longitude": 23.7697
  },
  "image": ogImageUrl,
  "priceRange": "€€",
  "foundingDate": "1980",
  "sameAs": ["https://www.facebook.com/katharismos.xalion"],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "08:00",
    "closes": "17:00"
  }
};
---
<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:locale" content="el_GR">
  <meta property="og:site_name" content="ΤΑΠΗΤΟΚΑΘΑΡΙΣΤΗΡΙΑ ΔΑΜΙΑΝΟΣ">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logo.png">

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
